{
  "name": "ristak-frontend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "design:audit": "node scripts/audit-design-system.mjs",
    "test:chat-notification-placement": "node scripts/test-chat-notification-placement.mjs",
    "test:chat-reconciliation": "node scripts/test-chat-message-reconciliation.mjs",
    "test:chat-delivery-state": "node scripts/test-chat-message-delivery-state.mjs",
    "test:chat-channel": "node scripts/test-chat-message-channel.mjs",
    "test:sites-video-rule-contract": "node scripts/test-sites-video-rule-contract.mjs",
    "test:sites-html-creation-flow": "node scripts/test-sites-html-creation-flow.mjs",
    "test:sites-imported-form-meta-trigger": "node scripts/test-sites-imported-form-meta-trigger.mjs",
    "test:appointment-modal-contract": "node scripts/test-appointment-modal-contract.mjs",
    "test:calendar-commercial-reports": "node scripts/test-calendar-commercial-reports.mjs",
    "test:web-analytics-plan-access": "node --test scripts/test-web-analytics-plan-access.cjs",
    "test:payment-links-plan-access": "node --test scripts/test-payment-links-plan-access.cjs",
    "test:highlevel-chat-send": "node scripts/test-highlevel-chat-send.mjs",
    "test:mcp-developers-ui": "node scripts/test-mcp-developers-ui.mjs",
    "test:oauth-consent": "node scripts/test-oauth-consent-flow.mjs",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "preview": "vite preview",
    "mobile:sync": "npm run build && cap sync",
    "mobile:sync:ios": "npm run build && npx -p node@22 -p @capacitor/cli@8.4.0 cap sync ios",
    "mobile:sync:android": "npm run build && npx -p node@22 -p @capacitor/cli@8.4.0 cap sync android",
    "mobile:ios:archive": "xcodebuild -project ../ios/app/Ristak.xcodeproj -scheme Ristak -configuration Release -destination 'generic/platform=iOS' -archivePath ../ios/app/build/Ristak.xcarchive -allowProvisioningUpdates archive",
    "mobile:ios:upload": "xcodebuild -exportArchive -archivePath ../ios/app/build/Ristak.xcarchive -exportPath ../ios/app/build/AppStore -exportOptionsPlist ../ios/app/ExportOptions-AppStore.plist -allowProvisioningUpdates",
    "mobile:android:aab": "npm run mobile:sync:android && cd android && ./gradlew bundleRelease",
    "mobile:add:ios": "cap add ios",
    "mobile:add:android": "cap add android",
    "mobile:open:ios": "cap open ios",
    "mobile:open:android": "cap open android"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/device": "^8.0.2",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@stripe/react-stripe-js": "^6.6.0",
    "@stripe/stripe-js": "^9.8.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.1.3",
    "rebill": "^1.17.28",
    "recharts": "^2.15.0",
    "tus-js-client": "^4.3.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@types/react": "^19.0.6",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.2",
    "vite": "^5.4.11"
  }
}
