# Production Environment Variables - TEMPLATE
# Este archivo es un EJEMPLO. Copia este archivo a .env.production y configura tu URL.

# URL del backend en Render (producción)
# REEMPLAZA CON LA URL DE TU SERVICIO EN RENDER
# Ejemplo: https://mi-ristak.onrender.com
VITE_API_URL=https://TU-SERVICIO.onrender.com

# IMPORTANTE:
# - NO uses la URL de otra persona
# - Esta URL la obtienes al deployar en Render
# - Debe apuntar a TU propio backend
