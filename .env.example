# ==============================================
# BACKEND - Variables de Entorno
# ==============================================

# Entorno
NODE_ENV=development

# Puerto del servidor (⚠️ NO CAMBIAR - SIEMPRE 3001)
PORT=3001

# ==============================================
# BASE DE DATOS
# ==============================================

# Este proyecto usa SQLite para base de datos local
# El archivo ristak.db se crea automáticamente en la raíz del proyecto
# NO necesitas configurar nada aquí - todo es automático

# ==============================================
# CONFIGURACIÓN DE APIS
# ==============================================

# HighLevel API
# Los tokens y configuración se guardan desde el panel de Settings
# No necesitas configurarlos aquí

# Meta Ads API
# Los tokens y configuración se guardan desde el panel de Settings
# No necesitas configurarlos aquí

# ==============================================
# URL DEL SERVIDOR
# ==============================================

# URL externa del servidor (para desarrollo local)
RENDER_EXTERNAL_URL=http://localhost:3001

# ==============================================
# FRONTEND - Variables de Entorno
# ==============================================
# Crear archivo frontend/.env con:

# URL del backend API (para desarrollo local)
# VITE_API_URL=http://localhost:3001

# ==============================================
# INSTRUCCIONES PARA DESARROLLO LOCAL
# ==============================================

# ⚠️ IMPORTANTE: SIEMPRE usa el script start-local.sh
# NUNCA arrancar frontend o backend por separado

# Desde la raíz del proyecto:
# bash start-local.sh

# Esto automáticamente:
# - Mata procesos viejos en puertos 3000 y 3001
# - Arranca el backend en puerto 3001
# - Arranca el frontend en puerto 3000
# - Abre el navegador
# - Usa SQLite local (ristak.db)

# ==============================================
# BASE DE DATOS SQLITE
# ==============================================

# La base de datos se crea automáticamente en:
# /Users/raulgomez/Desktop/Ristak - High Level/ristak.db

# Para ver los datos usa:
# - DB Browser for SQLite (https://sqlitebrowser.org)
# - TablePlus
# - Beekeeper Studio
