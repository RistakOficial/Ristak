# Ristak environment example
#
# Local development normally needs no root .env file. `start-local.sh` loads
# `backend/.env` when present and Vite proxies `/api` to localhost:3001.

# Runtime
NODE_ENV=development
PORT=3001

# Database
# Leave DATABASE_URL empty locally to use SQLite at ./ristak.db.
# Set DATABASE_URL in Render to use PostgreSQL.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Auth
# Required/recommended in production. Render generates this from render.yaml.
# JWT_SECRET=generate-a-long-random-secret

# Encryption
# Optional. If omitted, the app creates ENCRYPTION_MASTER_KEY and stores it in DB.
# Use a stable value if you want an external backup for encrypted tokens.
# ENCRYPTION_MASTER_KEY=64_hex_chars_or_more

# Public URLs / tracking
# Render provides RENDER_EXTERNAL_URL automatically in production.
RENDER_EXTERNAL_URL=http://localhost:3001
# Optional custom tracking domain without protocol.
# TRACKING_DOMAIN=collect.tudominio.com

# Frontend
# For local dev, frontend/vite.config.ts proxies `/api` to port 3001, so this
# can stay unset. In Render, render.yaml generates frontend/.env.production.
# VITE_API_URL=http://localhost:3001

# App móvil / notificaciones push
# Para builds nativos, VITE_API_URL debe apuntar al backend público HTTPS
# (por ejemplo https://tu-app.onrender.com). No uses localhost en el binario.
# VITE_API_URL=https://tu-dominio-publico.com

# Web Push/PWA
# Opcional: si faltan, el servidor crea llaves estables y las guarda en la base de datos.
# WEB_PUSH_PUBLIC_KEY=
# WEB_PUSH_PRIVATE_KEY=
# WEB_PUSH_SUBJECT=mailto:soporte@ristak.com

# Android nativo vía Firebase Cloud Messaging
# FCM_PROJECT_ID=
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Alternativa: FCM_SERVICE_ACCOUNT_FILE=/ruta/segura/service-account.json

# iOS nativo vía APNs
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_BUNDLE_ID=com.ristak.app
# APNS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# Alternativa: APNS_PRIVATE_KEY_FILE=/ruta/segura/AuthKey_XXXX.p8
# APNS_ENV=production

# Integration credentials
# HighLevel, Meta Ads and Stripe are configured from Settings in the app.
# Do not commit real tokens.
