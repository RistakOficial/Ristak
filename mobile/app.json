{
  "expo": {
    "name": "Ristak Native",
    "slug": "ristak-native-mobile",
    "version": "1.0.0",
    "description": "Android React Native mobile client for Ristak.",
    "scheme": "ristak-native",
    "orientation": "portrait",
    "icon": "./assets/ristak-light-mode-icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#07111f",
    "primaryColor": "#3278ff",
    "platforms": [
      "android"
    ],
    "android": {
      "package": "com.ristak.android",
      "icon": "./assets/ristak-light-mode-icon.png",
      "permissions": [
        "CAMERA",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#050505",
        "foregroundImage": "./assets/ristak-night-mode-icon.png",
        "monochromeImage": "./assets/ristak-monochrome-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-image-picker",
      "expo-audio",
      [
        "expo-notifications",
        {
          "enableBackgroundRemoteNotifications": true
        }
      ],
      "expo-location",
      "expo-video",
      "expo-background-task",
      "expo-web-browser"
    ]
  }
}
