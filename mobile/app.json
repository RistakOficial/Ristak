{
  "expo": {
    "name": "Ristak",
    "slug": "ristak-native-mobile",
    "version": "1.0.0",
    "description": "Android React Native mobile client for Ristak.",
    "scheme": "ristak-native",
    "orientation": "portrait",
    "icon": "./assets/ristak-light-mode-icon.png",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#050506",
    "primaryColor": "#1d1d1f",
    "platforms": [
      "android"
    ],
    "android": {
      "package": "com.ristak.android",
      "icon": "./assets/ristak-light-mode-icon.png",
      "permissions": [
        "CAMERA",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "RECORD_AUDIO"
      ],
      "blockedPermissions": [
        "android.permission.ACTIVITY_RECOGNITION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/ristak-light-mode-icon.png",
        "monochromeImage": "./assets/ristak-monochrome-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-image-picker",
      "expo-audio",
      [
        "expo-notifications",
        {
          "enableBackgroundRemoteNotifications": true
        }
      ],
      "expo-location",
      "expo-video",
      "expo-background-task",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/ristak-light-mode-icon.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "android": {
            "backgroundColor": "#ffffff",
            "image": "./assets/ristak-light-mode-icon.png",
            "imageWidth": 160,
            "resizeMode": "contain"
          }
        }
      ],
      "expo-web-browser"
    ]
  }
}
