# Local mobile store release configuration for this machine.
# Copy with: npm run mobile:release:init
#
# Never put real values in this example. The private copy is:
# .mobile-release.local.env
#
# Credential source:
# - installer: recommended. Store Apple/Google signing credentials in Ristak
#   Installer under Configuracion > Tiendas moviles. This local file only keeps
#   operator defaults and local fallback paths.
# - local: direct local signing/upload fallback. Requires every secret file and
#   password below to be present on this machine.
MOBILE_RELEASE_CREDENTIAL_SOURCE=installer
MOBILE_RELEASE_DEFAULT_PLATFORM=both
MOBILE_RELEASE_SUBMIT_FOR_REVIEW=false
MOBILE_RELEASE_GITHUB_BRANCH=main

# Installer-backed release dispatch.
MOBILE_RELEASE_INSTALLER_URL=

# iOS / App Store Connect.
MOBILE_RELEASE_IOS_VERSION=1.0.1
IOS_APPLE_ID=
IOS_APPLE_TEAM_ID=Y2L8669JNL
IOS_BUNDLE_ID=com.ristak.app
IOS_APP_STORE_CONNECT_KEY_ID=
IOS_APP_STORE_CONNECT_ISSUER_ID=
IOS_APP_STORE_CONNECT_API_KEY_PATH=.mobile-release/ios/AuthKey_REPLACE_KEY_ID.p8
IOS_DISTRIBUTION_CERTIFICATE_PATH=.mobile-release/ios/AppleDistribution.p12
IOS_DISTRIBUTION_CERTIFICATE_PASSWORD=
IOS_APPSTORE_PROVISIONING_PROFILE_PATH=.mobile-release/ios/RistakAppStore.mobileprovision
IOS_NOTIFICATION_SERVICE_PROVISIONING_PROFILE_PATH=.mobile-release/ios/RistakNotificationServiceAppStore.mobileprovision
IOS_CI_KEYCHAIN_PASSWORD=
IOS_EXPORT_OPTIONS_PLIST=frontend/ios/App/ExportOptions-AppStore.plist

# Android / Google Play.
MOBILE_RELEASE_ANDROID_VERSION_NAME=1.0
MOBILE_RELEASE_ANDROID_TRACK=internal
ANDROID_PACKAGE_NAME=com.ristak.app
ANDROID_KEYSTORE_PROPERTIES_PATH=frontend/android/app/keystore.properties
ANDROID_KEYSTORE_PATH=frontend/android/app/ristak-play-upload.jks
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_PATH=.mobile-release/android/google-play-service-account.json
