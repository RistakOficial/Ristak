{
  "name": "ristak-backend",
  "version": "1.0.0",
  "description": "Backend para Ristak - Dashboard de HighLevel + Meta Ads",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "meta:update-version": "node scripts/update-meta-version.mjs",
    "media:migrate-to-bunny": "node scripts/migrate-existing-media-to-bunny.mjs",
    "sync:ghl-catalog": "node scripts/sync-highlevel-endpoint-catalog.mjs ../tmp/highlevel-api-docs src/data/highlevelEndpointCatalog.js",
    "test": "node --test --test-concurrency=1 test/"
  },
  "dependencies": {
    "@openai/agents": "^0.11.6",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "file-type": "^21.3.4",
    "jszip": "^3.10.1",
    "luxon": "^3.5.0",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "nodemailer": "^8.0.11",
    "pg": "^8.16.3",
    "pino": "^9.14.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.35.1",
    "sqlite3": "^5.1.7",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
