{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "canvas-harness",
      "runtimeExecutable": "node",
      "runtimeArgs": ["_harness/server.mjs"],
      "port": 4599
    },
    {
      "name": "backend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start", "--prefix", "backend"],
      "port": 3001
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "frontend"],
      "port": 3000
    }
  ]
}
